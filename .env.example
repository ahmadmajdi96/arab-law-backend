NODE_ENV=development
HOST=0.0.0.0
PORT=3000
LOG_LEVEL=info

# Public app/origin settings
API_PUBLIC_URL=http://localhost:5556
FRONTEND_URL=http://host.docker.internal:5173
# Temporary permissive mode. Replace with explicit frontend origins before production hardening.
CORS_ORIGINS=*

# Supabase
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=your-publishable-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Recommended for local JWT verification; if absent the API falls back to supabase.auth.getUser.
SUPABASE_JWT_SECRET=

# Novita AI. The API is OpenAI-compatible.
NOVITA_API_KEY=your-novita-ai-key
NOVITA_AI_BASE_URL=https://api.novita.ai/openai
AI_DEFAULT_MODEL=deepseek/deepseek-r1
AI_TOKEN_BUDGET_ENFORCEMENT=true

# ElevenLabs Scribe/live transcription token minting.
ELEVENLABS_API_KEY=your-elevenlabs-key
ELEVENLABS_SCRIBE_TOKEN_URL=https://api.elevenlabs.io/v1/scribe/token

# Meeting room JWTs minted by this backend.
MEETING_TOKEN_SECRET=replace-with-a-long-random-meeting-secret

# Security
CRON_SECRET=replace-with-a-long-random-secret
PAYMENT_WEBHOOK_SECRET=replace-with-a-long-random-secret
RATE_LIMIT_MAX=600
RATE_LIMIT_WINDOW=1 minute

# Async jobs
REDIS_URL=redis://redis:6379
QUEUE_ENABLED=true

# Optional reminder dispatch webhook. If empty, reminders remain realtime/in-app only.
NOTIFICATION_WEBHOOK_URL=

# Observability
OTEL_ENABLED=true
OTEL_SERVICE_NAME=arab-law-api
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4318
