{
  "name": "arab-law-backend",
  "version": "1.0.0",
  "description": "Production-owned backend for arab.law with PostgreSQL, S3-compatible storage, AI gateway metering, workers, and observability.",
  "type": "module",
  "engines": {
    "node": ">=24.0.0",
    "npm": ">=11.0.0"
  },
  "scripts": {
    "dev": "tsx watch --env-file=.env src/main.ts",
    "dev:worker": "tsx watch --env-file=.env src/worker.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/main.js",
    "start:worker": "node dist/src/worker.js",
    "test": "vitest run",
    "test:integration": "RUN_INTEGRATION=1 vitest run",
    "benchmark": "tsx scripts/load-test.ts benchmark",
    "stress": "tsx scripts/load-test.ts stress",
    "lint": "biome check .",
    "format": "biome format --write .",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "docker:up": "docker compose up --build --scale api=3",
    "docker:down": "docker compose down --remove-orphans"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1075.0",
    "@aws-sdk/s3-request-presigner": "^3.1075.0",
    "@fastify/compress": "^8.0.1",
    "@fastify/cors": "^11.0.1",
    "@fastify/helmet": "^13.0.1",
    "@fastify/multipart": "^9.0.3",
    "@fastify/rate-limit": "^10.3.0",
    "@fastify/sensible": "^6.0.3",
    "@fastify/swagger": "^9.5.1",
    "@fastify/swagger-ui": "^5.2.3",
    "@opentelemetry/api": "^1.9.1",
    "@opentelemetry/auto-instrumentations-node": "^0.77.0",
    "@opentelemetry/exporter-metrics-otlp-http": "^0.219.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.219.0",
    "@opentelemetry/sdk-metrics": "^2.8.0",
    "@opentelemetry/sdk-node": "^0.219.0",
    "bullmq": "^5.41.1",
    "dotenv": "^16.4.7",
    "drizzle-orm": "^0.45.2",
    "fastify": "^5.2.1",
    "fastify-plugin": "^5.0.1",
    "fastify-raw-body": "^5.0.0",
    "jose": "^5.9.6",
    "nanoid": "^5.0.9",
    "pino": "^9.6.0",
    "postgres": "^3.4.9",
    "prom-client": "^15.1.3",
    "undici": "^7.3.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@emnapi/core": "^1.11.1",
    "@emnapi/runtime": "^1.11.1",
    "@types/node": "^22.13.4",
    "drizzle-kit": "^0.31.10",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3",
    "vitest": "^4.1.9"
  },
  "overrides": {
    "@esbuild-kit/core-utils": {
      "esbuild": "^0.25.12"
    }
  }
}
